{
  "manifest_version": 3,
  "name": "Ninja Order Builder",
  "version": "1.3.2",
  "description": "Build Shopify draft orders from Ninja Transfers cart data.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://ninjatransfers.com/*",
    "https://ninjatransfers.myshopify.com/*",
    "https://admin.shopify.com/*",
    "https://ninja-order-builder.vercel.app/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://ninja-order-builder.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ninja Order Builder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "key": ""
}