# ─────────────────────────────────────────────────────────────
# Ninja Order Builder Proxy v1.4 — Environment Variables
# Set all of these in Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Ninja Transfers ────────────────────────────────────────────
TRANSFERS_SHOP_DOMAIN=ninjatransfers.myshopify.com
TRANSFERS_CLIENT_ID=your_transfers_client_id
TRANSFERS_CLIENT_SECRET=your_transfers_client_secret

# ── Ninja Patches ──────────────────────────────────────────────
PATCHES_SHOP_DOMAIN=ninjapatches.myshopify.com
PATCHES_CLIENT_ID=your_patches_client_id
PATCHES_CLIENT_SECRET=your_patches_client_secret

# ── Shared ─────────────────────────────────────────────────────
PROXY_URL=https://ninja-order-builder.vercel.app
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
