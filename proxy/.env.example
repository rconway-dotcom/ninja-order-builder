# ─────────────────────────────────────────────────────────────
# Ninja Order Builder Proxy — Environment Variables
# Set all of these in Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Your Shopify store domain (no https://)
SHOP_DOMAIN=yourstore.myshopify.com

# From dev.shopify.com → your app → Settings tab
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# The URL of this Vercel deployment (no trailing slash)
# Set this after your first deploy, then redeploy
PROXY_URL=https://ninja-order-builder.vercel.app

# A long random string — used to sign session tokens
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
